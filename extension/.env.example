# Environment config for the extension.
#
# WXT (Vite) picks the file by build mode automatically:
#   wxt / wxt dev        → mode=development → .env.development
#   wxt build / wxt zip  → mode=production  → .env.production
#
# All values are public URLs (no secrets), so .env.development and
# .env.production are committed. `.env.local` and `.env.*.local` are
# git-ignored for personal overrides.
#
# WARNING: `.env.local` loads in EVERY mode (dev AND production zips) — never
# put environment-specific URLs there. Use `.env.development.local` for
# personal dev-only overrides (e.g. ngrok).

# Currents appview (API) base URL — no trailing slash.
VITE_CURRENTS_URL=https://api.currents.is

# Frontend login route the popup opens to authenticate.
VITE_LOGIN_PAGE_URL=https://currents.is/login/extension

# Frontend (web app) base URL.
VITE_CURRENTS_FRONTEND_URL=https://currents.is
