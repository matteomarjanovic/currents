# URL of the Currents appview (no trailing slash).
# Override for local dev / ngrok:
# VITE_CURRENTS_URL=https://your-ngrok-subdomain.ngrok-free.app
VITE_CURRENTS_URL=https://currents.is

# Login page URL (the frontend's extension login route).
# Override for local dev:
# VITE_LOGIN_PAGE_URL=http://localhost:5173/login/extension
VITE_LOGIN_PAGE_URL=https://currents.is/login/extension
