# -----------------------------------------------------------------------
# Currents — mac-mini deployment environment variables
# Copy this file to .env and fill in all required values.
# -----------------------------------------------------------------------

# The public domain for the appview (no https://, no trailing slash)
# This is the domain connected to your Cloudflare tunnel.
# Example: api.currents.example.com
DOMAIN=

# The Netlify URL of the frontend (no trailing slash)
# Example: https://currents.example.com
FRONTEND_URL=

# Random string used to sign session cookies — generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# AT Protocol confidential OAuth client — P-256 private key in multibase encoding
# Generate with the indigo keygen tool or:
#   go run github.com/bluesky-social/indigo/cmd/keygen@latest
CLIENT_SECRET_KEY=

# Key ID for CLIENT_SECRET_KEY (can be any stable identifier)
CLIENT_SECRET_KEY_ID=primary

# Cloudflare Tunnel token — create a tunnel at dash.cloudflare.com > Zero Trust > Tunnels,
# point it to http://appview:8080, then paste the token here.
CLOUDFLARE_TUNNEL_TOKEN=

# -----------------------------------------------------------------------
# Optional overrides (defaults are fine for most deployments)
# -----------------------------------------------------------------------

# PostgreSQL password (default: appview)
# DB_PASSWORD=appview

# Inference server URL — by default assumes the inference server runs directly
# on the host (outside Docker). Start it with:
#   cd inference && uvicorn main:app --reload
# INFERENCE_URL=http://host.docker.internal:8000
