{
  "lexicon": 1,
  "id": "is.currents.feed.getSaves",
  "defs": {
    "main": {
      "type": "query",
      "description": "Hydrate a list of saves by their AT-URIs. Missing URIs are omitted from the output.",
      "parameters": {
        "type": "params",
        "required": [
          "uris"
        ],
        "properties": {
          "uris": {
            "type": "array",
            "minLength": 1,
            "maxLength": 25,
            "items": {
              "type": "string",
              "format": "at-uri"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "saves"
          ],
          "properties": {
            "saves": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "is.currents.feed.defs#saveView"
              }
            }
          }
        }
      }
    }
  }
}
