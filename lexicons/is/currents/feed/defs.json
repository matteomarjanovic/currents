{
  "lexicon": 1,
  "id": "is.currents.feed.defs",
  "defs": {
    "collectionView": {
      "type": "object",
      "required": [
        "uri",
        "cid",
        "author",
        "name",
        "createdAt"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "cid": {
          "type": "string",
          "format": "cid"
        },
        "author": {
          "type": "ref",
          "ref": "is.currents.actor.defs#profileView"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "saveCount": {
          "type": "integer"
        },
        "previewImages": {
          "type": "array",
          "maxLength": 4,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        },
        "viewer": {
          "type": "ref",
          "ref": "#collectionViewerState",
          "description": "Viewer-specific state. Only present when the request is authenticated."
        }
      }
    },
    "collectionViewerState": {
      "type": "object",
      "description": "Metadata about the requesting account's relationship with this collection. Only present when the request is authenticated.",
      "properties": {
        "starred": {
          "type": "boolean",
          "description": "Whether the authenticated user has starred this collection."
        }
      }
    },
    "saveView": {
      "type": "object",
      "required": [
        "uri",
        "author",
        "content",
        "createdAt"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri"
        },
        "author": {
          "type": "ref",
          "ref": "is.currents.actor.defs#profileView"
        },
        "content": {
          "type": "union",
          "refs": [
            "is.currents.content.defs#imageView"
          ],
          "closed": false,
          "description": "Content payload for this save."
        },
        "text": {
          "type": "string"
        },
        "originUrl": {
          "type": "string",
          "format": "uri"
        },
        "resaveOf": {
          "type": "ref",
          "ref": "com.atproto.repo.strongRef"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime"
        },
        "viewer": {
          "type": "ref",
          "ref": "#saveViewerState",
          "description": "Viewer-specific state. Only present when the request is authenticated."
        }
      }
    },
    "saveViewerState": {
      "type": "object",
      "description": "Metadata about the requesting account's relationship with this save. Only present when the request is authenticated.",
      "properties": {
        "saves": {
          "type": "array",
          "description": "The viewer's own saves of this item, one per collection they have saved it in.",
          "items": {
            "type": "object",
            "required": [
              "collectionUri",
              "saveUri"
            ],
            "properties": {
              "collectionUri": {
                "type": "string",
                "format": "at-uri"
              },
              "saveUri": {
                "type": "string",
                "format": "at-uri"
              }
            }
          }
        }
      }
    }
  }
}