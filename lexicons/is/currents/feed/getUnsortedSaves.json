{
  "lexicon": 1,
  "id": "is.currents.feed.getUnsortedSaves",
  "defs": {
    "main": {
      "type": "query",
      "description": "List an actor's unsorted saves — saves that belong to no collection and live only on the actor's profile. Auth is optional; if provided, viewer-specific state is included in the returned save views.",
      "parameters": {
        "type": "params",
        "required": [
          "actor"
        ],
        "properties": {
          "actor": {
            "type": "string",
            "format": "at-identifier",
            "description": "DID or handle of the actor whose unsorted saves to list."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "saves"
          ],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "saves": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "is.currents.feed.defs#saveView"
              }
            }
          }
        }
      }
    }
  }
}
