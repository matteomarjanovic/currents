{
  "lexicon": 1,
  "id": "is.currents.feed.getExploreFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a ranked feed of saves from across the network. Auth is optional; if provided, viewer-specific state is included. The personalized flag is only effective for authenticated requests.",
      "parameters": {
        "type": "params",
        "properties": {
          "personalized": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "A value between 0 and 1 controlling the degree of personalization. Only effective for authenticated requests; ignored otherwise.",
            "default": 0
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "feed"
          ],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "feed": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "is.currents.feed.defs#saveView"
              }
            }
          }
        }
      }
    }
  }
}