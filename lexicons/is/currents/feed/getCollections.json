{
  "lexicon": 1,
  "id": "is.currents.feed.getCollections",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the authenticated user's collections, each with preview image URLs. Requires authentication.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "collections"
          ],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "collections": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "is.currents.feed.defs#collectionView"
              }
            }
          }
        }
      }
    }
  }
}