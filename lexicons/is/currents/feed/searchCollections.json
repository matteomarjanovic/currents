{
  "lexicon": 1,
  "id": "is.currents.feed.searchCollections",
  "defs": {
    "main": {
      "type": "query",
      "description": "Search collections by name across all actors. Auth is optional; if provided, viewer-specific state is included.",
      "parameters": {
        "type": "params",
        "required": ["q"],
        "properties": {
          "q": {
            "type": "string",
            "description": "Collection name search query.",
            "maxLength": 2048
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 25
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["collections"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "collections": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "is.currents.feed.defs#collectionView"
              }
            }
          }
        }
      }
    }
  }
}
