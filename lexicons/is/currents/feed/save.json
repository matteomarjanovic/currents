{
  "lexicon": 1,
  "id": "is.currents.feed.save",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "image",
          "collection",
          "createdAt"
        ],
        "properties": {
          "image": {
            "type": "blob",
            "accept": [
              "image/*"
            ],
            "maxSize": 20000000
          },
          "collection": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "originUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 2000
          },
          "attribution": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "maxLength": 2000
              },
              "license": {
                "type": "string",
                "maxLength": 500
              },
              "credit": {
                "type": "string",
                "maxLength": 500
              }
            }
          },
          "text": {
            "type": "string",
            "maxLength": 1000
          },
          "resaveOf": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
