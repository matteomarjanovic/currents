{
  "lexicon": 1,
  "id": "is.currents.feed.save",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "content",
          "createdAt"
        ],
        "properties": {
          "content": {
            "type": "union",
            "refs": [
              "is.currents.content.image"
            ],
            "closed": false
          },
          "collection": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "originUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 2000
          },
          "text": {
            "type": "string",
            "maxLength": 1000
          },
          "resaveOf": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}