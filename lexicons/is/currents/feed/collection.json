{
  "lexicon": 1,
  "id": "is.currents.feed.collection",
  "defs": {
    "main": {
      "type": "record",
      "description": "A collection of saved items curated by an account.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "name",
          "createdAt"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable name of the collection.",
            "maxGraphemes": 100,
            "maxLength": 1000
          },
          "description": {
            "type": "string",
            "description": "Optional description shown with the collection.",
            "maxGraphemes": 1000,
            "maxLength": 10000
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}