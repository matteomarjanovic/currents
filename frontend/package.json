{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:e2e": "playwright test",
		"build:mobile": "CAPACITOR=1 vite build && cap sync",
		"cap:sync": "cap sync",
		"cap:open:android": "cap open android",
		"cap:open:ios": "cap open ios",
		"dev:android": "CAPACITOR=1 vite build --mode development && cap sync && cap run android",
		"dev:ios": "CAPACITOR=1 vite build --mode development && cap sync && cap run ios"
	},
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/instrument-sans": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.18.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vite-pwa/sveltekit": "^1.1.0",
		"bits-ui": "^2.17.0",
		"clsx": "^2.1.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@capacitor-community/safe-area": "^8.0.0",
		"@capacitor/android": "^8.0.0",
		"@capacitor/app": "^8.0.0",
		"@capacitor/browser": "^8.0.0",
		"@capacitor/camera": "^8.0.0",
		"@capacitor/cli": "^8.0.0",
		"@capacitor/core": "^8.0.0",
		"@capacitor/filesystem": "^8.1.2",
		"@capacitor/ios": "^8.0.0",
		"@capacitor/splash-screen": "^8.0.0",
		"@capacitor/status-bar": "^8.0.0",
		"@capawesome-team/capacitor-secure-preferences": "^0.3.2",
		"@masonry-grid/svelte": "^1.1.1",
		"mode-watcher": "^1.1.0",
		"send-intent": "^7.0.0"
	}
}
